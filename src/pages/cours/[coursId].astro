---
import Layout from '../../layouts/Layout.astro';
import { COURS } from '../../data/cours';

export function getStaticPaths() {
  return COURS.map(cours => ({ params: { coursId: cours.id }, props: { cours } }));
}

const { cours } = Astro.props;

const colors = {
  'color-peach':    '#f5c9b3',
  'color-sage':     '#b8d4c2',
  'color-lavender': '#c9c5e8',
  'color-sky':      '#b3d4e8',
  'color-rose':     '#e8c5c9',
  'color-butter':   '#e8ddb3',
};
---

<Layout title={cours.titre} description={cours.description}>
  <div style="max-width:1200px;margin:0 auto;padding:48px 24px">

    <a href="/" class="back-link">← Tous les cours</a>

    <div style="display:flex;align-items:flex-start;gap:20px;margin-bottom:48px;padding-bottom:36px;border-bottom:1px solid var(--border)">
      <div style={`width:64px;height:64px;border-radius:18px;display:flex;align-items:center;justify-content:center;font-size:2rem;background:color-mix(in srgb,${colors[cours.color]} 40%,var(--bg-subtle));flex-shrink:0`}>
        {cours.emoji}
      </div>
      <div>
        <h1 style="font-family:var(--font-display);font-size:clamp(1.4rem,3.5vw,2.2rem);color:var(--text-primary);margin-bottom:10px;font-weight:400">{cours.titre}</h1>
        <p style="color:var(--text-secondary);font-size:1rem">{cours.description}</p>
        {cours.chapitres.length > 0 && (
          <div style="display:flex;gap:16px;margin-top:16px;font-size:0.82rem;color:var(--text-muted)">
            <span>📄 {cours.chapitres.length} chapitre{cours.chapitres.length > 1 ? 's' : ''}</span>
          </div>
        )}
      </div>
    </div>

    {cours.chapitres.length === 0 ? (
      <div style="text-align:center;padding:64px 24px;color:var(--text-muted)">
        <div style="font-size:2.5rem;margin-bottom:16px">🚧</div>
        <p style="font-size:1rem;color:var(--text-secondary)">Les chapitres de ce cours seront ajoutés prochainement.</p>
      </div>
    ) : (
      <div>
        <h2 style="font-family:var(--font-body);font-size:0.75rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text-muted);margin-bottom:16px">
          Programme du cours
        </h2>
        <div style="display:flex;flex-direction:column;gap:12px">
          {cours.chapitres.map((ch, i) => (
            <a
              href={`/cours/${ch.slug}`}
              class="chapter-row"
              style={`animation-delay:${i * 60}ms`}
            >
              <div class="chapter-row__num">{String(ch.num).padStart(2, '0')}</div>
              <div style="flex:1;min-width:0">
                <div style="font-weight:500;color:var(--text-primary);font-size:0.95rem;margin-bottom:4px">{ch.titre}</div>
                <div style="font-size:0.82rem;color:var(--text-secondary)">{ch.resume}</div>
              </div>
              {ch.duree && (
                <div style="font-size:0.78rem;color:var(--text-muted);flex-shrink:0">⏱ {ch.duree}</div>
              )}
              <span style="color:var(--accent);flex-shrink:0">→</span>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</Layout>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.82rem;
    color: var(--text-muted);
    text-decoration: none;
    margin-bottom: 32px;
    transition: color 200ms;
  }
  .back-link:hover { color: var(--accent); }

  .chapter-row {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 18px 20px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all 200ms;
    animation: fadeUp .4s ease both;
  }
  .chapter-row:hover {
    transform: translateX(4px);
    box-shadow: var(--shadow-md);
    border-color: color-mix(in srgb, var(--accent) 30%, var(--border));
  }
  .chapter-row__num {
    width: 36px; height: 36px;
    border-radius: 10px;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.8rem; font-weight: 700;
    color: var(--text-muted);
    flex-shrink: 0;
  }
</style>
