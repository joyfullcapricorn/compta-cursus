---
import Layout from './Layout.astro';
import { COURS } from '../data/cours';

interface Props {
  frontmatter: {
    titre: string;
    coursId: string;
    chapitreNum: number;
    resume: string;
    duree?: string;
  }
}

const { frontmatter } = Astro.props;
const cours = COURS.find(c => c.id === frontmatter.coursId);
const currentSlug = Astro.url.pathname;
---

<Layout title={frontmatter.titre} description={frontmatter.resume}>
  <div class="course-layout">

    <!-- Sidebar -->
    <aside class="sidebar">
      <a href={`/cours/${frontmatter.coursId}`} class="sidebar__back">
        ← {cours?.emoji} {cours?.titre}
      </a>
      <div class="sidebar__title">Chapitres</div>
      <ul class="sidebar__nav">
        {cours?.chapitres.map(ch => {
          const href = `/cours/${ch.slug}`;
          const isActive = currentSlug === href || currentSlug === href + '/';
          return (
            <li>
              <a href={href} class={isActive ? 'active' : ''}>
                <span class="num">{ch.num}.</span>
                {ch.titre}
              </a>
            </li>
          );
        })}
      </ul>
    </aside>

    <!-- Main content -->
    <main class="content-area">
      <nav class="content-breadcrumb">
        <a href="/">Accueil</a>
        <span class="sep">/</span>
        <a href={`/cours/${frontmatter.coursId}`}>{cours?.titre}</a>
        <span class="sep">/</span>
        <span>{frontmatter.titre}</span>
      </nav>

      <div class="chapter-header">
        <div class="chapter-num">Chapitre {frontmatter.chapitreNum}</div>
        <h1 class="chapter-title">{frontmatter.titre}</h1>
        <div class="chapter-meta">
          <span>{frontmatter.resume}</span>
          {frontmatter.duree && <span>· ⏱ {frontmatter.duree}</span>}
        </div>
      </div>

      <!-- In-page search -->
      <div style="margin-bottom:32px;position:relative" id="chapter-search-wrapper">
        <span class="search-icon" style="font-size:0.85rem">🔍</span>
        <input
          type="text"
          class="search-bar"
          id="chapter-search"
          placeholder="Rechercher dans ce chapitre…"
          style="font-size:0.875rem;padding:10px 38px 10px 40px"
          autocomplete="off"
        />
        <button class="search-clear" id="chapter-search-clear">✕</button>
        <p class="search-results-count" id="chapter-search-count" style="text-align:left;padding-left:4px;margin-top:6px"></p>
      </div>

      <div class="prose" id="chapter-content">
        <slot />
      </div>

      <!-- Navigation between chapters -->
      {cours && (() => {
        const idx = cours.chapitres.findIndex(c => c.num === frontmatter.chapitreNum);
        const prev = cours.chapitres[idx - 1];
        const next = cours.chapitres[idx + 1];
        return (
          <div style="display:flex;justify-content:space-between;gap:16px;margin-top:56px;padding-top:32px;border-top:1px solid var(--border)">
            {prev ? (
              <a href={`/cours/${prev.slug}`} style="flex:1;display:flex;align-items:center;gap:10px;padding:16px;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-md);text-decoration:none;transition:all 200ms;max-width:280px" class="nav-btn">
                <span style="color:var(--text-muted)">←</span>
                <div>
                  <div style="font-size:0.7rem;color:var(--text-muted);margin-bottom:3px">Précédent</div>
                  <div style="font-size:0.875rem;font-weight:500;color:var(--text-primary)">{prev.titre}</div>
                </div>
              </a>
            ) : <div />}
            {next && (
              <a href={`/cours/${next.slug}`} style="flex:1;display:flex;align-items:center;justify-content:flex-end;gap:10px;padding:16px;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-md);text-decoration:none;transition:all 200ms;max-width:280px;text-align:right;margin-left:auto" class="nav-btn">
                <div>
                  <div style="font-size:0.7rem;color:var(--text-muted);margin-bottom:3px">Suivant</div>
                  <div style="font-size:0.875rem;font-weight:500;color:var(--text-primary)">{next.titre}</div>
                </div>
                <span style="color:var(--text-muted)">→</span>
              </a>
            )}
          </div>
        );
      })()}
    </main>
  </div>
</Layout>

<style>
  .nav-btn:hover {
    border-color: color-mix(in srgb, var(--accent) 30%, var(--border));
    box-shadow: var(--shadow-sm);
  }
</style>

<script>
  // In-chapter full-text search with highlight
  const input = document.getElementById('chapter-search') as HTMLInputElement;
  const clearBtn = document.getElementById('chapter-search-clear');
  const countEl = document.getElementById('chapter-search-count');
  const content = document.getElementById('chapter-content');

  if (!content || !input) { /* skip */ }
  else {
    // Save original HTML
    const originalHTML = content.innerHTML;

    function escapeRe(s: string) {
      return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    }

    function doSearch(query: string) {
      if (!query.trim()) {
        content!.innerHTML = originalHTML;
        countEl!.textContent = '';
        return;
      }

      // Restore original, then highlight
      content!.innerHTML = originalHTML;

      // Walk text nodes and highlight
      const re = new RegExp(`(${escapeRe(query.trim())})`, 'gi');
      let count = 0;

      function walk(node: Node) {
        if (node.nodeType === Node.TEXT_NODE) {
          const text = node.textContent || '';
          if (re.test(text)) {
            re.lastIndex = 0;
            const span = document.createElement('span');
            span.innerHTML = text.replace(re, '<mark>$1</mark>');
            node.parentNode!.replaceChild(span, node);
            count += (text.match(re) || []).length;
            re.lastIndex = 0;
          }
        } else if (
          node.nodeType === Node.ELEMENT_NODE &&
          !['SCRIPT','STYLE','MARK'].includes((node as Element).tagName)
        ) {
          Array.from(node.childNodes).forEach(walk);
        }
      }

      walk(content!);

      // Scroll to first mark
      const first = content!.querySelector('mark');
      if (first) first.scrollIntoView({ behavior: 'smooth', block: 'center' });

      countEl!.textContent = count > 0
        ? `${count} occurrence${count > 1 ? 's' : ''} trouvée${count > 1 ? 's' : ''}`
        : 'Aucune occurrence trouvée';
    }

    let debounce: ReturnType<typeof setTimeout>;
    input.addEventListener('input', (e) => {
      clearTimeout(debounce);
      debounce = setTimeout(() => doSearch((e.target as HTMLInputElement).value), 250);
    });

    clearBtn?.addEventListener('click', () => {
      input.value = '';
      doSearch('');
      input.focus();
    });
  }
</script>
